    title: "dbCAN"
    url: https://github.com/linnabrown/run_dbcan
  - type: software
    title: "IQ-TREE2"
    url: http://www.iqtree.org
  - type: software
    title: "MAFFT"
    url: https://mafft.cbrc.jp/alignment/software/
  - type: software
    title: "trimAl"
    url: http://trimal.cgenomics.org
  - type: software
    title: "clinker"
    url: https://github.com/gamcil/clinker
